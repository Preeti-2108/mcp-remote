# GitLab On-Premise Configuration
# Copy this file to .env and fill in your values

# Your GitLab instance URL (required)
GITLAB_URL=https://gitlab.example.com/

# Personal Access Token (required)
# Create one at: ${GITLAB_URL}/-/user_settings/personal_access_tokens
#
# Required scopes:
#   - "api" for full access (read + write: create issues, add comments)
#   - "read_api" + "read_repository" for read-only access
GITLAB_TOKEN=glpat-XXXXXXXXX

# SSL certificate verification (optional, default: true)
# Set to false for self-signed certificates
GITLAB_SSL_VERIFY=true
